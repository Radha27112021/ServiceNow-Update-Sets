<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_script_include"><sys_script_include action="INSERT_OR_UPDATE"><access>public</access><active>true</active><api_name>global.SyslogFilterAjax</api_name><caller_access/><client_callable>true</client_callable><description/><mobile_callable>false</mobile_callable><name>SyslogFilterAjax</name><sandbox_callable>false</sandbox_callable><script><![CDATA[var SyslogFilterAjax = Class.create();
SyslogFilterAjax.prototype = Object.extendsObject(AbstractAjaxProcessor, {

    getSyslogEntries: function() {
        var sourceStr = this.getParameter('sysparm_source') || '';
        sourceStr = sourceStr.trim();

        if (!sourceStr) {
            return JSON.stringify([]);
        }

        // Build time threshold — 24 hours ago in GlideDateTime
        var threshold = new GlideDateTime();
        threshold.addSeconds(-86400); // 60 * 60 * 24

        var gr = new GlideRecord('syslog');
        gr.addQuery('sys_created_on', '>=', threshold);
        gr.addQuery('source', 'CONTAINS', sourceStr).addOrCondition('message', 'CONTAINS', sourceStr);
        gr.orderByDesc('sys_created_on');
        gr.setLimit(200); // safety cap; UI scrolls for >10
        gr.query();

        var results = [];

        while (gr.next()) {
            results.push({
                created_on: gr.getValue('sys_created_on'),
                message: gr.getValue('message') || '',
				source: gr.getValue('source') || ''
            });
        }

        return JSON.stringify(results);
    },

    type: 'SyslogFilterAjax'
});]]></script><sys_class_name>sys_script_include</sys_class_name><sys_created_by>admin</sys_created_by><sys_created_on>2026-02-28 19:15:52</sys_created_on><sys_id>4bf276d2c31f321051e8b342b40131ac</sys_id><sys_mod_count>1</sys_mod_count><sys_name>SyslogFilterAjax</sys_name><sys_package display_value="Global" source="global">global</sys_package><sys_policy/><sys_scope display_value="Global">global</sys_scope><sys_update_name>sys_script_include_4bf276d2c31f321051e8b342b40131ac</sys_update_name><sys_updated_by>admin</sys_updated_by><sys_updated_on>2026-02-28 20:23:39</sys_updated_on></sys_script_include><sys_es_latest_script action="INSERT_OR_UPDATE"><id>4bf276d2c31f321051e8b342b40131ac</id><sys_created_by>admin</sys_created_by><sys_created_on>2026-02-28 19:15:51</sys_created_on><sys_id>198376d2c31f321051e8b342b4013151</sys_id><sys_mod_count>0</sys_mod_count><sys_updated_by>admin</sys_updated_by><sys_updated_on>2026-02-28 19:15:51</sys_updated_on><table>sys_script_include</table><use_es_latest>true</use_es_latest></sys_es_latest_script></record_update>
