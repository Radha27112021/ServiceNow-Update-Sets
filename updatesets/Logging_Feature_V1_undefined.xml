<?xml version="1.0" encoding="UTF-8"?><record_update table="sys_ui_macro"><sys_ui_macro action="INSERT_OR_UPDATE"><active>true</active><category>general</category><description>For filtering the syslog entries and displaying them on the server side itself.</description><media_type/><name>syslog_identifier</name><scoped_name/><sys_class_name>sys_ui_macro</sys_class_name><sys_created_by>admin</sys_created_by><sys_created_on>2026-02-28 19:12:56</sys_created_on><sys_id>2e52b216c3db321051e8b342b40131e9</sys_id><sys_mod_count>7</sys_mod_count><sys_name>syslog_identifier</sys_name><sys_package display_value="Global" source="global">global</sys_package><sys_policy/><sys_scope display_value="Global">global</sys_scope><sys_update_name>sys_ui_macro_2e52b216c3db321051e8b342b40131e9</sys_update_name><sys_updated_by>admin</sys_updated_by><sys_updated_on>2026-03-02 10:50:23</sys_updated_on><xml><![CDATA[<?xml version="1.0" encoding="utf-8" ?>
<j:jelly trim="false" xmlns:j="jelly:core" xmlns:g="glide" xmlns:j2="null" xmlns:g2="null">

    <style>
        .syslog-outer {
            width: 100%;
            padding-top: 10px;
            padding-bottom: 10px;
            padding-right: 14%;
            padding-left: 18%;
        }

        .syslog-search-area {
            width: 100%;
            margin-bottom: 8px;
        }

        .syslog-input {
            width: calc(100% - 90px);
            padding: 6px 10px;
            border: 1px solid #bbb;
            border-radius: 4px 0 0 4px;
            font-size: 13px;
            height: 32px;
            box-sizing: border-box;
            vertical-align: middle;
        }

        .syslog-btn {
            width: 82px;
            padding: 6px 10px;
            background-color: #107010;
            color: #fff;
            border: none;
            border-radius: 0 4px 4px 0;
            font-size: 13px;
            cursor: pointer;
            height: 32px;
            vertical-align: middle;
        }

        .syslog-btn:hover {
            background-color: #0a520a;
        }

        .syslog-status {
            font-size: 12px;
            color: #555;
            margin-bottom: 6px;
            min-height: 16px;
        }

        .syslog-results-container {
            max-height: 260px;
            overflow-y: auto;
            border: 1px solid #d0d0d0;
            border-radius: 4px;
            background: #fff;
            display: none;
            width: 100%;
        }

        .syslog-table {
            width: 100%;
            border-collapse: collapse;
            font-size: 12.5px;
            table-layout: fixed;
        }

        .syslog-table thead {
            background-color: #1b6c1b;
            color: #fff;
        }

        .syslog-table thead th {
            padding: 8px 12px;
            text-align: left;
            font-weight: 600;
            position: sticky;
            top: 0;
            z-index: 1;
            background-color: #1b6c1b;
        }

        .syslog-table thead th.col-ts {
            width: 160px;
        }

        .syslog-table thead th.col-src {
            width: 160px;
        }

        .syslog-table tbody td.col-src {
            white-space: nowrap;
            color: #555;
            width: 160px;
        }

        .syslog-table tbody tr {
            border-bottom: 1px solid #eee;
        }

        .syslog-table tbody tr:hover {
            background-color: #f0f7f0;
        }

        .syslog-table tbody td {
            padding: 7px 12px;
            vertical-align: top;
            color: #333;
            word-break: break-word;
        }

        .syslog-table tbody td.col-ts {
            white-space: nowrap;
            color: #555;
            width: 160px;
        }

        .syslog-no-results {
            padding: 16px;
            text-align: center;
            color: #888;
            font-size: 13px;
            display: none;
            border: 1px solid #d0d0d0;
            border-radius: 4px;
            background: #fff;
        }
    </style>

    <tr>
        <td colspan="2" style="padding: 8px 12px;">

            <div class="syslog-outer">

                <div class="syslog-search-area">
                    <input type="text" class="syslog-input" id="syslog_source_input" placeholder="Enter source string to filter syslog..." />
                    <button type="button" class="syslog-btn" onclick="syslogSearch()">Search</button>
                </div>

                <div class="syslog-status" id="syslog_status"></div>

                <div id="syslog_no_results" class="syslog-no-results">
                    No syslog records found matching that identifier in the last 24 hours.
                </div>

                <div class="syslog-results-container" id="syslog_results_container">
                    <table class="syslog-table">
                        <thead>
                            <tr>
                                <th class="col-ts">Timestamp</th>
                                <th>Message</th>
                                <th class="col-src">Source</th>
                            </tr>
                        </thead>
                        <tbody id="syslog_results_body"></tbody>
                    </table>
                </div>

            </div>

        </td>
    </tr>

    <script language="javascript">
        function syslogSearch() {
            var sourceStr = gel('syslog_source_input').value.trim();
            var statusEl = gel('syslog_status');
            var container = gel('syslog_results_container');
            var noResults = gel('syslog_no_results');
            var tbody = gel('syslog_results_body');

            if (!sourceStr) {
                statusEl.textContent = 'Please enter a identifier string.';
                return;
            }

            statusEl.textContent = 'Searching...';
            container.style.display = 'none';
            noResults.style.display = 'none';
            tbody.innerHTML = '';

            var ga = new GlideAjax('SyslogFilterAjax');
            ga.addParam('sysparm_name', 'getSyslogEntries');
            ga.addParam('sysparm_source', sourceStr);

            ga.getXMLAnswer(function(answer) {
                var data;
                try {
                    data = JSON.parse(answer);
                } catch (e) {
                    statusEl.textContent = 'Error parsing response.';
                    return;
                }

                if (!data || data.length === 0) {
                    statusEl.textContent = 'Search complete.';
                    noResults.style.display = 'block';
                    return;
                }

                statusEl.textContent = 'Showing ' + data.length + ' record(s) from the last 24 hours.';
                container.style.display = 'block';

                data.forEach(function(entry) {
                    var row = document.createElement('tr');
                    var tdTs = document.createElement('td');
                    tdTs.className = 'col-ts';
                    tdTs.textContent = entry.created_on;
                    var tdMsg = document.createElement('td');
                    tdMsg.textContent = entry.message;
                    var tdSrc = document.createElement('td');
					tdTs.className = 'col-src';
                    tdSrc.textContent = entry.source;
                    row.appendChild(tdTs);
                    row.appendChild(tdMsg);
                    row.appendChild(tdSrc);
                    tbody.appendChild(row);
                });
            });
        }
    </script>

</j:jelly>]]></xml></sys_ui_macro></record_update>
